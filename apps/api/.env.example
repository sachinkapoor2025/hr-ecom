DYNAMODB_ENDPOINT=http://localhost:8000
ENVIRONMENT=local
# Per-domain tables (override individually if needed; default to hr-ecom-<domain>-<ENVIRONMENT>)
PRODUCTS_TABLE=hr-ecom-products-local
ORDERS_TABLE=hr-ecom-orders-local
CARTS_TABLE=hr-ecom-carts-local
CUSTOMERS_TABLE=hr-ecom-customers-local
EVENTS_TABLE=hr-ecom-events-local
CONFIG_TABLE=hr-ecom-config-local
EMAIL_CAMPAIGNS_TABLE=hr-ecom-email-campaigns-local
REMINDER_EMAILS_TABLE=hr-ecom-reminder-emails-local
PENDING_PAYMENT_UNSUB_TABLE=hr-ecom-pending-payment-unsub-local
# Staging load tests only — never true in production
LOAD_TEST_MODE=false
DEV_AUTH_ENABLED=true
USE_LOCAL_UPLOADS=true
USE_MEMORY_DB=true
LOCAL_API_URL=http://localhost:3001
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1
# Stripe — set in GitHub Secrets (deployed to Lambda via SAM); publishable key in Amplify
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  (Amplify only)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Email notifications (contact form, new orders) — NEVER commit real passwords
SMTP_HOST=smtp.usarakhi.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=order@usarakhi.com
SMTP_PASS=
SMTP_FROM=order@usarakhi.com
NOTIFY_EMAIL=order@usarakhi.com,priya.yadav@mydgv.com

# Marketing campaigns (/admin/email) — separate from transactional SMTP above.
# Password can also be set in Admin → Email → Settings (preferred).
MARKETING_TRANSPORT=smtp
MARKETING_SMTP_HOST=smtp-prod.mailrcld.com
MARKETING_SMTP_PORT=587
MARKETING_SMTP_SECURE=false
MARKETING_SMTP_USER=order@usarakhi.com
MARKETING_SMTP_PASS=

# USPS Shipping (OAuth 2.0 v3 REST API — never commit real credentials)
# Production: https://apis.usps.com | TEM/sandbox: https://apis-tem.usps.com
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
USPS_SECRET_ARN=
USPS_BASE_URL=https://apis.usps.com
# Label purchase (optional until auto-purchase enabled)
USPS_CRID=
USPS_MID=
USPS_EPS_ACCOUNT_NUMBER=
USPS_PAYMENT_AUTHORIZATION_TOKEN=

# Orange County vendor order API (X-Vendor-Api-Key header)
ORANGE_COUNTY_VENDOR_API_KEY=

# Optional WhatsApp for customer notifications + admin coupons (Meta Cloud API and/or Twilio)
# When set, transactional messages also go to WhatsApp (coupons, order status, abandoned cart, etc.)
# Email remains primary — WhatsApp failures never block the order/email flow.
# If unset, admin UI still gets a wa.me deep link to send manually
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
