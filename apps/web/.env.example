NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# In Amplify / GitHub: set RAZOR_KEY_ID (same value as NEXT_PUBLIC_RAZORPAY_KEY_ID)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=us-east-1
# Cognito hosted UI domain — from stack output CognitoHostedUIDomain (e.g. hr-ecom-prod-123456789.auth.us-east-1.amazoncognito.com)
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_DEV_AUTH=true
